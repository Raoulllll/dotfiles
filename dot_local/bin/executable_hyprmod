#!/bin/sh
# distrobox_binary
# name: arch-box
if [ -z "${CONTAINER_ID}" ]; then
	exec "/run/current-system/sw/bin/distrobox-enter"  -n arch-box  --  '/usr/bin/hyprmod'  "$@"
elif [ -n "${CONTAINER_ID}" ] && [ "${CONTAINER_ID}" != "arch-box" ]; then
	exec distrobox-host-exec '/home/roehl/.local/bin/hyprmod' "$@"
else
	exec  '/usr/bin/hyprmod' "$@"
fi
